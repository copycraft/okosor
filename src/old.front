            icon: <Lock size={24} />
        },
        {
            id: 'medium',
            title: 'FAMILY_SHIELD',
            subtitle: 'Családi Biztonság',
            price: '550 000 Ft',
            features: ['Smart Server v1', '12x Választható szenzor', '2x IP Kamera', 'Távoli elérés'],
