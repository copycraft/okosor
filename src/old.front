import ContactForm from './components/ContactForm';

// Tiszta, újrahasználható Logo komponens
const SmartLogo = ({ className = "h-8 w-8" }) => (
    <div className={`relative flex items-center justify-center ${className}`}>
        <div className="absolute inset-0 bg-blue-600/10 rounded-lg rotate-3" />
        <div className="relative bg-white border-2 border-blue-600 p-1 rounded-lg">
            <Shield className="text-blue-600" size={18} />
        </div>
    </div>
);

export default function SmarthomeHome({ onBack }: { onBack?: () => void }): JSX.Element {
    const [mobileMenuOpen, setMobileMenuOpen] = useState(false);

    const products = [
